# LLM provider: "lmstudio" (dev) or "groq" (prod)
LLM_PROVIDER=lmstudio

# LM Studio — local endpoint, no real key required
LMSTUDIO_MODEL=qwen2.5-7b-instruct

# Groq — production
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# Agno tracing (optional) — connect to app.agno.com to view traces in the cloud dashboard
# Without this key, traces are still written locally to tmp/traces.db
AGNO_API_KEY=your-agno-api-key-here
